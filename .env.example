# Lab04 local configuration. Copy to `.env` only for local overrides.
# Do not commit real secrets.

REPO_URL=https://github.com/huggingface/datasets.git
REPO_NAME=huggingface/datasets
REPO_DIR=data/datasets

# Internal Docker-network address. Parser, Spark, and Connect use this because
# the parser runs as a Compose service.
KAFKA_BOOTSTRAP_INTERNAL=broker:9092

# Optional host address if you intentionally run parser_service outside Docker.
KAFKA_BOOTSTRAP_EXTERNAL=localhost:29092

KAFKA_SERVICE=broker
CONNECT_SERVICE=connect
CONNECT_URL=http://localhost:8083
CONNECTOR_NAME=cpg-neo4j-sink

NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

MONGO_URI=mongodb://mongo:27017/
MONGO_DATABASE=cpg
MONGO_COLLECTION=file_metadata

SPARK_SERVICE=spark
SPARK_CHECKPOINT=/mnt/checkpoints/cpg_metadata
SCHEMA_VERSION=1.0
